rules_version = '2';
service firebase.storage {
  function isShitoAdmin() {
    return request.auth != null
      && (request.auth.uid == "n5JTPLsxpyQPeC5qQtraSrBa4rG3" || request.auth.uid == "QayqN0MpBTQK6je44JwAXWapoQU2" || request.auth.uid == "20kR47W8PfTGIvGxGOGRsB2JiFA3" || request.auth.token.email == "wilsonteofilosouza@live.com" || request.auth.token.email == "drakenteofilo@gmail.com" || request.auth.token.admin == true);
  }

  function hasAdminPanelAccess() {
    return request.auth != null
      && (request.auth.token.panelRole == "admin"
          || request.auth.token.panelRole == "super_admin"
          || request.auth.token.admin == true);
  }

  function isSafeSegment(value) {
    return value.matches('^[A-Za-z0-9_-]{2,128}$');
  }

  /**
   * Dono do path (uid no segmento) pode escrever na própria pasta sem depender de custom claim
   * `panelRole` (muitos criadores só têm role no RTDB). Staff continua com override.
   */
  function canWriteOwnerPath(ownerUid) {
    return isShitoAdmin()
      || hasAdminPanelAccess()
      || (request.auth != null
          && request.auth.uid == ownerUid
          && isSafeSegment(ownerUid));
  }

  match /b/{bucket}/o {
    /**
     * URLs públicas enumeráveis: capas/{uid}/*, manga/{uid}/{obra}/*, obras/{uid}/{obra}/*
     * Qualquer pessoa pode tentar varrer uid/obra (segmentos validados por isSafeSegment).
     * Conteúdo sensível não deve depender do segredo do path — use nomes de ficheiro imprevisíveis
     * e regras de leitura acima. Ver docs/firebase-public-surface.md.
     */
    match /capas/{ownerUid}/{fileName} {
      allow read: if true;
      allow write: if isSafeSegment(ownerUid)
                   && canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && !request.resource.contentType.matches('.*svg.*')
                   && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')));
    }

    /**
     * Páginas de capítulo (AdminPanel → manga/…) e capas/banners por obra (ObrasAdmin → obras/…).
     * Mesma política: imagens até 5MB, sem SVG; dono do segmento ou staff.
     */
    match /{workImageRoot}/{ownerUid}/{obra}/{fileName} {
      allow read: if workImageRoot == "manga" || workImageRoot == "obras";
      allow write: if (workImageRoot == "manga" || workImageRoot == "obras")
                   && isSafeSegment(ownerUid)
                   && isSafeSegment(obra)
                   && canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && !request.resource.contentType.matches('.*svg.*')
                   && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')));
    }

    match /avatares/{fileName} {
      allow read: if true;
      allow write: if isShitoAdmin()
                   && (request.resource == null || (request.resource.size < 1024 * 1024
                   && request.resource.contentType == "image/webp"
                   && fileName.matches('.*\\.webp$')));
    }

    /** Banner de perfil público do criador (upload antes de virar mangaka). WebP comprimido no cliente (~400KB). */
    match /creator_profile/{ownerUid}/{fileName} {
      allow read: if true;
      allow write: if isSafeSegment(ownerUid)
                   && request.auth != null
                   && request.auth.uid == ownerUid
                   && (request.resource == null || (request.resource.size < 600 * 1024
                   && request.resource.contentType == "image/webp"
                   && fileName.lower().matches('.*\\.webp$')));
    }

    /**
     * Assets da loja (imagens de vitrine + PDF digital).
     * Imagens: leitura pública (URLs no catálogo). PDF: só com Firebase Auth (evita hotlink anônimo);
     * upload continua restrito ao dono do segmento / staff.
     */
    match /loja_produtos/{ownerUid}/{fileName} {
      allow read: if isSafeSegment(ownerUid)
                  && resource != null
                  && (
                    (resource.contentType.matches('image/.*')
                     && !resource.contentType.matches('.*svg.*'))
                    || (resource.contentType == "application/pdf" && request.auth != null)
                  );
      allow write: if isSafeSegment(ownerUid)
                   && canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 60 * 1024 * 1024
                   && ((request.resource.contentType == "application/pdf"
                        && fileName.lower().matches('.*\\.pdf$'))
                       || (request.resource.contentType.matches('image/.*')
                           && !request.resource.contentType.matches('.*svg.*')
                           && request.resource.size < 5 * 1024 * 1024
                           && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')))));
    }

    match /print_on_demand/{ownerUid}/{fileName} {
      allow read: if isShitoAdmin()
                   || hasAdminPanelAccess()
                   || (request.auth != null && request.auth.uid == ownerUid);
      /** Mesmo limite do cliente: PDF ate 55 MB na UI; capa ate 8 MB. */
      allow write: if isSafeSegment(ownerUid)
                   && request.auth != null
                   && request.auth.uid == ownerUid
                   && (request.resource == null || (
                        (request.resource.contentType == "application/pdf"
                         && request.resource.size < 56 * 1024 * 1024
                         && fileName.lower().matches('.*\\.pdf$'))
                        || (request.resource.contentType.matches('image/.*')
                            && !request.resource.contentType.matches('.*svg.*')
                            && request.resource.size < 8 * 1024 * 1024
                            && fileName.lower().matches('.*\\.(jpe?g|png|webp)$'))
                      ));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
