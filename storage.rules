rules_version = '2';
service firebase.storage {
  function isShitoAdmin() {
    return request.auth != null
      && (request.auth.uid == "n5JTPLsxpyQPeC5qQtraSrBa4rG3"
          || request.auth.uid == "QayqN0MpBTQK6je44JwAXWapoQU2"
          || request.auth.uid == "20kR47W8PfTGIvGxGOGRsB2JiFA3"
          || request.auth.token.email == "wilsonteofilosouza@live.com"
          || request.auth.token.email == "drakenteofilo@gmail.com"
          || request.auth.token.admin == true);
  }

  function isMangaka() {
    return request.auth != null && request.auth.token.panelRole == "mangaka";
  }

  function canWriteOwnerPath(ownerUid) {
    return isShitoAdmin()
      || (request.auth != null
          && request.auth.uid == ownerUid
          && isMangaka());
  }

  match /b/{bucket}/o {
    match /capas/{ownerUid}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && !request.resource.contentType.matches('.*svg.*')
                   && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')));
    }

    match /manga/{ownerUid}/{obra}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && !request.resource.contentType.matches('.*svg.*')
                   && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')));
    }

    match /obras/{ownerUid}/{obra}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerPath(ownerUid)
                   && (request.resource == null || (request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && !request.resource.contentType.matches('.*svg.*')
                   && fileName.lower().matches('.*\\.(jpe?g|png|webp)$')));
    }

    match /avatares/{fileName} {
      allow read: if true;
      allow write: if isShitoAdmin()
                   && (request.resource == null || (request.resource.size < 1024 * 1024
                   && request.resource.contentType == "image/webp"
                   && fileName.matches('.*\\.webp$')));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
